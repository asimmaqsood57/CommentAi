# PostgreSQL — used by docker-compose to create the DB
POSTGRES_USER=commentai
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=commentai

# Prisma — docker-compose overrides this to point at the postgres container.
# Set this only if running the API outside Docker.
DATABASE_URL=postgresql://commentai:your_strong_password_here@localhost:5432/commentai

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Groq (AI provider)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RevenueCat webhook
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# Server port (default 3000)
PORT=3000
